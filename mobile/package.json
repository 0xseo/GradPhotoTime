{
  "name": "grad-photo-time-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:lan": "expo start --lan",
    "start:local": "EXPO_OFFLINE=1 expo start --localhost -c",
    "start:tunnel": "expo start --tunnel",
    "android": "EXPO_OFFLINE=1 expo start --android --localhost -c",
    "android:lan": "expo start --android --lan",
    "android:local": "EXPO_OFFLINE=1 expo start --android --localhost -c",
    "android:tunnel": "expo start --android --tunnel",
    "ios": "expo start --ios",
    "ios:local": "EXPO_OFFLINE=1 expo start --ios --localhost -c",
    "web": "expo start --web"
  },
  "dependencies": {
    "expo": "latest",
    "expo-secure-store": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0"
  },
  "devDependencies": {
    "@types/react": "latest",
    "typescript": "latest"
  }
}
