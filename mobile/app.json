{
  "expo": {
    "name": "GradPhotoTime",
    "slug": "grad-photo-time",
    "scheme": "gradphototime",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.xseo.gradphototime",
      "supportsTablet": true
    },
    "android": {
      "package": "com.xseo.gradphototime",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
